{
  "name": "slack-emoji-bot",
  "version": "0.1.3",
  "description": "Self-hosted Slack bot that adds three context-aware emoji reactions to selected messages.",
  "private": false,
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hietan/slack-emoji-bot.git"
  },
  "bugs": {
    "url": "https://github.com/Hietan/slack-emoji-bot/issues"
  },
  "homepage": "https://github.com/Hietan/slack-emoji-bot#readme",
  "keywords": [
    "slack",
    "emoji",
    "bot",
    "cloud-run",
    "gemini",
    "terraform"
  ],
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm test:integration && pnpm build && pnpm validate:config && pnpm scan:sensitive && pnpm scan:production",
    "lint": "eslint \"src/**/*.ts\" \"scripts/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run tests/unit tests/contract",
    "test:coverage": "vitest run tests/unit tests/contract --coverage",
    "test:integration": "vitest run tests/integration",
    "validate:config": "tsx scripts/validate-config.ts",
    "scan:sensitive": "tsx scripts/scan-sensitive-content.ts",
    "scan:production": "tsx scripts/scan-production-readiness.ts",
    "render:slack-manifest": "tsx scripts/render-slack-manifest.ts"
  },
  "dependencies": {
    "@google-cloud/firestore": "^8.6.0",
    "@google-cloud/tasks": "^6.2.1",
    "@google/genai": "^2.10.0",
    "@slack/web-api": "^7.9.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "pino": "^9.7.0",
    "yaml": "^2.8.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.3",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.29.0",
    "supertest": "^7.1.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1",
    "vitest": "^3.2.4"
  }
}
