# Runtime
NODE_ENV=production
PORT=8080
LOG_LEVEL=info

# Slack app identity
SLACK_TEAM_ID=T0123456789
SLACK_APP_ID=A0123456789
TARGET_CHANNEL_IDS=C0123456789,C9876543210

# Receiver
SLACK_SIGNING_SECRET=replace-in-secret-manager
WORKER_URL=https://slack-emoji-bot-worker-example.a.run.app
GCP_PROJECT_ID=your-gcp-project
GCP_REGION=asia-northeast1
CLOUD_TASKS_QUEUE_ID=emoji-reaction-jobs
TASK_INVOKER_SERVICE_ACCOUNT_EMAIL=slack-emoji-bot-task-invoker@your-gcp-project.iam.gserviceaccount.com
MAX_ANALYSIS_TEXT_CHARS=2000

# Worker
SLACK_BOT_TOKEN=replace-in-secret-manager
GEMINI_API_KEY=replace-in-secret-manager
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_TIMEOUT_MS=8000
SLACK_TIMEOUT_MS=5000
GEMINI_UNPAID_TERMS_ACKNOWLEDGED=false
EMOJI_CONFIG_PATH=/app/config/emoji.default.yaml
CUSTOM_EMOJI_CACHE_TTL_SECONDS=600
FIRESTORE_DATABASE_ID=(default)
PROCESS_RECORD_TTL_DAYS=7
DRY_RUN=false
